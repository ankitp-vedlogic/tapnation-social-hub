# ─── Sequence WaaS ────────────────────────────────────────────────
# Get from: https://sequence.build → Your Project → Settings
EXPO_PUBLIC_SEQUENCE_PROJECT_ACCESS_KEY=your_project_access_key_here
EXPO_PUBLIC_SEQUENCE_WAAS_CONFIG_KEY=your_waas_config_key_here

# ─── Google OAuth ──────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
EXPO_PUBLIC_OPENROUTER_API_KEY=your_ai_key